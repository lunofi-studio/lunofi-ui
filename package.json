{
  "name": "lunofi-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Calm, customizable copy-paste UI components built on Base UI and Tailwind CSS.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo build",
    "build:packages": "turbo build --filter=./packages/*",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "registry:build": "turbo registry:build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "storybook": "turbo storybook",
    "test": "turbo test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.0",
    "@lunofi/eslint-config": "workspace:*",
    "@lunofi/tsconfig": "workspace:*",
    "eslint": "^9.39.4",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.6",
      "react-dom": "^19.2.6"
    }
  }
}
